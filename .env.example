# path: .env.example

# ── Database (AWS RDS) ──────────────────────────────
DATABASE_URL=postgresql://finmarket_user:yourpassword@your-rds-endpoint.amazonaws.com:5432/finmarket

# ── Redis (AWS ElastiCache) ─────────────────────────
REDIS_URL=redis://your-elasticache-endpoint.amazonaws.com:6379/0

# ── AWS Credentials ─────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=finmarket-raw-data

# ── App Settings ────────────────────────────────────
APP_ENV=development
APP_NAME=FinMarket Intelligence
DEBUG=True
SECRET_KEY=change-this-to-a-random-string

# ── External APIs (Phase 2) ─────────────────────────
ALPHA_VANTAGE_API_KEY=your_key
NEWS_API_KEY=your_key

# ── AI (Phase 4) ────────────────────────────────────
GROQ_API_KEY=your_key